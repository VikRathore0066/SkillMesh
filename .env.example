# SkillMesh Environment Variables
# Copy this to .env.local and fill in values

# JWT Secret - generate a random string for production
JWT_SECRET=skillmesh-dev-secret-change-in-production

# Optional: GitHub API token for artifact verification
GITHUB_TOKEN=

# Optional: Figma API token for design artifact verification
FIGMA_TOKEN=

# Database path (default: ./skillmesh.db)
DATABASE_PATH=./skillmesh.db
